# --- Database (Neon Postgres) ---
# Pooled connection string (for the app at runtime)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# Direct (non-pooled) connection string (for Prisma migrations)
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Auth.js v5 ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me"
AUTH_TRUST_HOST="true"

# --- Owner account (used once by `npm run db:seed`) ---
OWNER_EMAIL="you@example.com"
OWNER_PASSWORD="choose-a-strong-password"
OWNER_NAME="Owner"
OWNER_TIMEZONE="Asia/Jerusalem"

# --- Anthropic (Vercel AI SDK) ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# --- Telegram bot (optional; email digest is used as fallback until this is set) ---
# 1. Message @BotFather on Telegram, /newbot, follow the prompts.
# 2. Put the token it gives you here.
TELEGRAM_BOT_TOKEN=""
# Bot's @username, shown in Settings instructions (without the @)
TELEGRAM_BOT_USERNAME=""
# Any random string; also used to validate incoming Telegram webhook calls.
# Generate with: openssl rand -hex 24
TELEGRAM_WEBHOOK_SECRET=""

# --- Email fallback digest (optional; used when Telegram isn't connected) ---
# https://resend.com/api-keys
RESEND_API_KEY=""
RESEND_FROM_EMAIL="LifeOS <onboarding@resend.dev>"

# --- Cron protection ---
# Generate with: openssl rand -hex 24
# Vercel automatically sends this as `Authorization: Bearer <value>` to your
# Cron Job routes when CRON_SECRET is set as a project env var.
CRON_SECRET=""

# --- Deployed app URL (used to register the Telegram webhook) ---
APP_URL="https://your-project.vercel.app"
