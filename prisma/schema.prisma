generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String   @id @default(cuid())
  email                 String   @unique
  passwordHash          String
  name                  String?
  timezone              String   @default("Asia/Jerusalem")
  morningCheckinTime    String   @default("08:00")
  eveningCheckinTime    String   @default("22:00")
  telegramChatId        String?
  telegramLinkCode      String?  @unique
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  goals            Goal[]
  tasks            Task[]
  habits           Habit[]
  transactions     Transaction[]
  workouts         Workout[]
  supplementLogs   SupplementLog[]
  sleepLogs        SleepLog[]
  weightLogs       WeightLog[]
  learningItems    LearningItem[]
  trades           Trade[]
  notes            Note[]
  projects         Project[]
  aiConversations  AiConversation[]
  dailyReviews     DailyReview[]
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  ARCHIVED
}

model Goal {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  category    String?
  status      GoalStatus @default(ACTIVE)
  progress    Int        @default(0)
  deadline    DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tasks Task[]

  @@index([userId])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  goalId      String?
  goal        Goal?        @relation(fields: [goalId], references: [id], onDelete: SetNull)
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId])
  @@index([goalId])
}

model Habit {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  color         String   @default("#38bdf8")
  targetPerWeek Int      @default(7)
  archived      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  entries HabitEntry[]

  @@index([userId])
}

model HabitEntry {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  completed Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([habitId, date])
  @@index([habitId])
}

enum TransactionType {
  INCOME
  EXPENSE
  INVESTMENT
}

model Transaction {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      TransactionType
  amount    Float
  currency  String          @default("USD")
  category  String
  note      String?
  date      DateTime        @db.Date
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([userId])
  @@index([userId, date])
}

model Workout {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  type        String
  durationMin Int?
  notes       String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model SupplementLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  dosage    String?
  takenAt   DateTime @db.Date
  createdAt DateTime @default(now())

  @@index([userId])
}

model SleepLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  hours     Float
  quality   Int?
  notes     String?
  createdAt DateTime @default(now())

  @@unique([userId, date])
}

model WeightLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  weightKg  Float
  notes     String?
  createdAt DateTime @default(now())

  @@unique([userId, date])
}

enum LearningType {
  BOOK
  COURSE
  ARTICLE
  VIDEO
}

enum LearningStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  DROPPED
}

model LearningItem {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  author     String?
  type       LearningType   @default(BOOK)
  status     LearningStatus @default(PLANNED)
  progress   Int            @default(0)
  rating     Int?
  notes      String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([userId])
}

enum TradeDirection {
  LONG
  SHORT
}

enum TradeStatus {
  OPEN
  CLOSED
}

model Trade {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol     String
  direction  TradeDirection
  status     TradeStatus    @default(OPEN)
  entryPrice Float
  exitPrice  Float?
  size       Float?
  pnl        Float?
  emotion    String?
  mistake    String?
  note       String?
  openedAt   DateTime
  closedAt   DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([userId])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String
  tags      String[] @default([])
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  DONE
  ARCHIVED
}

model Project {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  status      ProjectStatus @default(PLANNING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId])
}

enum AiChannel {
  WEB
  TELEGRAM
}

model AiConversation {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   AiChannel @default(WEB)
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  messages AiMessage[]

  @@index([userId])
}

enum AiRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           AiRole
  content        String
  toolName       String?
  toolCallId     String?
  createdAt      DateTime       @default(now())

  @@index([conversationId])
}

enum ReviewType {
  MORNING
  EVENING
}

enum SentVia {
  TELEGRAM
  EMAIL
  NONE
}

model DailyReview {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime   @db.Date
  type      ReviewType
  content   String
  sentVia   SentVia    @default(NONE)
  createdAt DateTime   @default(now())

  @@unique([userId, date, type])
  @@index([userId])
}
